{
  "name": "@allurereport/web-classic",
  "version": "3.13.1",
  "description": "The static files for Allure Classic Report",
  "keywords": [
    "allure",
    "html",
    "report",
    "testing"
  ],
  "license": "Apache-2.0",
  "author": "Qameta Software",
  "repository": "https://github.com/allure-framework/allure3",
  "type": "module",
  "types": "./types.d.ts",
  "scripts": {
    "clean": "rimraf dist",
    "dev": "run-s dev:demo dev:copy dev:serve",
    "dev:demo": "rimraf out/demo && yarn run -T allure generate ${ALLURE_RESULTS_DIR:-../sandbox/allure-results} --config=./allurerc-dev.mjs --output=./out/demo",
    "dev:copy": "rimraf out/dev/data out/dev/widgets && mkdir -p out/dev && cp -R out/demo/data out/dev/data && cp -R out/demo/widgets out/dev/widgets",
    "dev:serve": "webpack serve --mode development",
    "build": "run-s clean 'build:prod:*'",
    "build:dev": "run-s clean 'build:dev:*'",
    "build:prod:single": "SINGLE_FILE_MODE=1 webpack --mode production",
    "build:prod:multi": "webpack --mode production",
    "build:dev:single": "SINGLE_FILE_MODE=1 webpack --mode development",
    "build:dev:multi": "webpack --mode development",
    "lint": "oxlint --import-plugin src test features stories",
    "test": "vitest run",
    "lint:fix": "oxlint --import-plugin --fix src test features stories"
  },
  "dependencies": {
    "@allurereport/charts-api": "3.13.1",
    "@allurereport/core-api": "3.13.1",
    "@allurereport/web-commons": "3.13.1",
    "@allurereport/web-components": "3.13.1",
    "@preact/signals": "^2.6.1",
    "clsx": "^2.1.1",
    "d3-shape": "^3.2.0",
    "i18next": "^24.0.2",
    "md5": "^2.3.0",
    "preact": "^10.28.2",
    "prismjs": "^1.30.0",
    "split.js": "^1.6.5"
  },
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@babel/plugin-transform-react-jsx": "^7.27.1",
    "@babel/preset-env": "^7.27.2",
    "@babel/preset-typescript": "^7.27.1",
    "@floating-ui/dom": "^1.6.12",
    "@types/babel__core": "^7.20.5",
    "@types/d3-shape": "^3.1.8",
    "@types/md5": "^2.3.5",
    "@types/node": "^20",
    "@types/prismjs": "^1.26.5",
    "@types/underscore": "^1",
    "@vitest/runner": "^2",
    "@vitest/snapshot": "^2.1.9",
    "allure-js-commons": "^3",
    "allure-vitest": "^3",
    "autoprefixer": "^10.4.20",
    "babel-loader": "^9.2.1",
    "babel-plugin-prismjs": "^2.1.0",
    "css-loader": "^7.1.4",
    "file-loader": "^6.2.0",
    "filesize": "^10.1.6",
    "fork-ts-checker-webpack-plugin": "^9.0.2",
    "globals": "^15.9.0",
    "handlebars-loader": "^1.7.3",
    "html-webpack-plugin": "^5.6.3",
    "mini-css-extract-plugin": "^2.9.1",
    "npm-run-all2": "^7.0.1",
    "postcss": "^8.5.10",
    "rimraf": "^6",
    "sass": "^1.79.1",
    "sass-loader": "^16.0.1",
    "style-loader": "^4.0.0",
    "svg-sprite-loader": "^6.0.11",
    "typescript": "^5",
    "underscore": "^1.13.8",
    "vitest": "^4.1.0",
    "webpack": "^5",
    "webpack-cli": "^7",
    "webpack-dev-server": "^5.2.4",
    "webpack-manifest-plugin": "^6"
  }
}