{
  "name": "@allurereport/summary",
  "version": "3.13.1",
  "description": "Allure Summary Plugin – dashboard page generator with charts for Allure Report",
  "keywords": [
    "allure",
    "html",
    "plugin",
    "report",
    "testing"
  ],
  "license": "Apache-2.0",
