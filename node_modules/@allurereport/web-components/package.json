    "@nivo/pie": "^0.99.0",
    "@nivo/text": "^0.99.0",
    "@nivo/theming": "^0.99.0",
    "@nivo/tooltip": "^0.99.0",
    "@nivo/treemap": "^0.99.0",
    "@preact/compat": "^18.3.1",
    "@preact/signals": "^2.6.1",
    "@react-spring/web": "^10.0.3",
    "clsx": "^2.1.1",
