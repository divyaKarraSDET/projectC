{
  "name": "@allurereport/git",
  "version": "3.13.1",
  "description": "Git metadata collection for Allure Git Flow",
  "keywords": [
    "allure",
    "git",
    "report",
    "testing"
  ],
  "license": "Apache-2.0",
  "author": "Qameta Software",
