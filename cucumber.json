{
    "default" : {
        "paths" : [
         "src/test/features/*.feature"
        ],
        "publishQuite" : true,
        "dryrun" : false,
        "require" : [
            "src/test/steps/*.ts",
            "src/test/utils/*.ts"
        ],
        "requireModule" : [
            "ts-node/register"
        ],
        "format" : [
            "html:cucumber-report.html",
             "allure-cucumberjs/reporter"
        ],
        "formatOptions" : {
            "snippetInterface" : "async-await"
        }
    }
}